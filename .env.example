# Copy to .env and fill in your values
# cp .env.example .env

# Neo4j (required - no fallbacks)
# When Neo4j runs on the SAME machine as the pipeline (e.g. your desktop):
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here

# When pipeline runs on a different machine, use your desktop's IP:
# NEO4J_URI=bolt://192.168.1.100:7687
